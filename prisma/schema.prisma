generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  SALES
  STOCK_MANAGER
  ACCOUNTANT
  HR
  WAREHOUSE
  READ_ONLY
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DocumentType {
  QUOTE
  INVOICE
  PROFORMA
  CREDIT_NOTE
  PURCHASE_ORDER
  DELIVERY_NOTE
  RECEIPT
}

enum DocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
  PAID
  PARTIALLY_PAID
  OVERDUE
}

enum PaymentMode {
  CASH
  CHECK
  TRANSFER
  CARD
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model Company {
  id        String     @id @default(cuid())
  name      String
  ice       String?
  taxId     String?
  rc        String?
  phone     String?
  email     String?
  address   String?
  city      String?
  logoUrl   String?
  stampUrl  String?
  signUrl   String?
  users     User[]
  clients   Client[]
  suppliers Supplier[]
  products  Product[]
  documents Document[]
  deliveryNotes DeliveryNote[]
  purchases PurchaseInvoice[]
  cashEntries CashEntry[]
  employees Employee[]
  employeeContracts EmployeeContract[]
  attendances Attendance[]
  hrLeaves HrLeave[]
  salarySlips SalarySlip[]
  salaryAdvances SalaryAdvance[]
  hrDocuments HrDocument[]
  expenses  Expense[]
  categories Category[]
  movements  StockMovement[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id           String     @id @default(cuid())
  companyId    String?
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(READ_ONLY)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}

model Client {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  ice         String?
  taxId       String?
  rc          String?
  phone       String?
  email       String?
  address     String?
  city        String?
  balance     Decimal    @default(0)
  documents   Document[]
  deliveryNotes DeliveryNote[]
  reminders   Reminder[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId])
  @@index([companyId, ice])
}

model Supplier {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  ice         String?
  taxId       String?
  rc          String?
  phone       String?
  email       String?
  address     String?
  city        String?
  balance     Decimal           @default(0)
  purchases   PurchaseInvoice[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([companyId])
  @@index([companyId, ice])
}

model Category {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([companyId, name])
  @@index([companyId])
}

model Product {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id])
  reference     String
  designation   String
  description   String?
  imageUrl      String?
  purchasePrice Decimal         @default(0)
  salePrice     Decimal
  vatRate       Decimal         @default(20)
  stock         Int             @default(0)
  minStock      Int             @default(0)
  lines         DocumentLine[]
  deliveryLines DeliveryNoteLine[]
  purchaseLines PurchaseInvoiceLine[]
  movements     StockMovement[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([companyId, reference])
  @@index([companyId])
}

model Document {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?          @relation(fields: [clientId], references: [id])
  type        DocumentType
  status      DocumentStatus   @default(DRAFT)
  number      String
  issueDate   DateTime         @default(now())
  dueDate     DateTime?
  subtotal    Decimal          @default(0)
  vatTotal    Decimal          @default(0)
  total       Decimal          @default(0)
  paidAmount  Decimal          @default(0)
  notes       String?
  lines       DocumentLine[]
  payments    Payment[]
  sourceId    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([companyId, type, number])
  @@index([companyId, status])
  @@index([companyId, clientId])
  @@index([companyId, clientId, type])
}

model DocumentLine {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  designation String
  quantity    Decimal
  unitPrice   Decimal
  vatRate     Decimal
  total       Decimal
}

model Payment {
  id          String      @id @default(cuid())
  documentId  String
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  amount      Decimal
  mode        PaymentMode
  reference   String?
  paidAt      DateTime    @default(now())
}

model DeliveryNote {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  number            String
  status            DocumentStatus     @default(DRAFT)
  issueDate         DateTime           @default(now())
  internalReference String?
  deliveryAddress   String?
  city              String?
  deliveryTerms     String?
  internalNotes     String?
  lines             DeliveryNoteLine[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([companyId, number])
  @@index([companyId, clientId])
  @@index([companyId, status])
}

model DeliveryNoteLine {
  id                String       @id @default(cuid())
  deliveryNoteId    String
  deliveryNote      DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?     @relation(fields: [productId], references: [id])
  reference         String?
  designation       String
  orderedQuantity   Decimal
  deliveredQuantity Decimal
  unit              String       @default("Pièce")
  observations      String?
}

model PurchaseInvoice {
  id         String                @id @default(cuid())
  companyId  String
  company    Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier              @relation(fields: [supplierId], references: [id])
  number     String
  status     DocumentStatus        @default(DRAFT)
  issueDate  DateTime              @default(now())
  dueDate    DateTime?
  subtotal   Decimal               @default(0)
  vatTotal   Decimal               @default(0)
  total      Decimal               @default(0)
  paidAmount Decimal               @default(0)
  notes      String?
  lines      PurchaseInvoiceLine[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([companyId, number])
  @@index([companyId, supplierId])
  @@index([companyId, status])
}

model PurchaseInvoiceLine {
  id                String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?        @relation(fields: [productId], references: [id])
  designation       String
  quantity          Decimal
  unitPrice         Decimal
  vatRate           Decimal
  total             Decimal
}

model CashEntry {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  category  String
  label     String
  amount    Decimal
  mode      PaymentMode
  reference String?
  entryDate DateTime    @default(now())
  createdAt DateTime    @default(now())

  @@index([companyId, entryDate])
  @@index([companyId, type])
}

model Expense {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal
  mode      PaymentMode
  spentAt   DateTime    @default(now())
  createdAt DateTime    @default(now())

  @@index([companyId])
}

model Employee {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  photoUrl      String?
  firstName     String
  lastName      String
  cin           String
  phone         String?
  email         String?
  address       String?
  city          String?
  birthDate     DateTime?
  hireDate      DateTime
  position      String
  department    String
  contractType  String
  baseSalary    Decimal            @default(0)
  status        String             @default("actif")
  contracts     EmployeeContract[]
  attendances   Attendance[]
  leaves        HrLeave[]
  salarySlips   SalarySlip[]
  advances      SalaryAdvance[]
  documents     HrDocument[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, cin])
}

model EmployeeContract {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type           String
  startDate      DateTime
  endDate        DateTime?
  salary         Decimal  @default(0)
  position       String
  signedFileUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([companyId, type])
}

model Attendance {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workDate       DateTime
  checkIn        DateTime?
  checkOut       DateTime?
  lateMinutes    Int      @default(0)
  workedHours    Decimal  @default(0)
  createdAt      DateTime @default(now())

  @@index([companyId, employeeId])
  @@index([companyId, workDate])
}

model HrLeave {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String
  reason      String
  startDate   DateTime
  endDate     DateTime
  days        Decimal  @default(0)
  status      String   @default("en attente")
  balance     Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([companyId, status])
}

model SalarySlip {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month           String
  baseSalary      Decimal  @default(0)
  bonuses         Decimal  @default(0)
  advances        Decimal  @default(0)
  deductions      Decimal  @default(0)
  unpaidAbsences  Decimal  @default(0)
  netSalary       Decimal  @default(0)
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  @@unique([companyId, employeeId, month])
  @@index([companyId, month])
}

model SalaryAdvance {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount      Decimal
  mode        PaymentMode
  paidAt      DateTime    @default(now())
  deducted    Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@index([companyId, employeeId])
  @@index([companyId, paidAt])
}

model HrDocument {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String
  title       String
  fileUrl     String?
  issuedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([companyId, employeeId])
  @@index([companyId, type])
}

model StockMovement {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockMovementType
  quantity  Int
  reason    String
  reference String?
  note      String?
  createdAt DateTime @default(now())

  @@index([companyId, productId])
  @@index([companyId, type])
  @@index([companyId, createdAt])
}

model Reminder {
  id        String   @id @default(cuid())
  companyId String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject   String
  note      String?
  dueAt     DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([companyId, clientId])
}

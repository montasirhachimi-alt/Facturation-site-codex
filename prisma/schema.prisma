generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  SALES
  STOCK_MANAGER
  ACCOUNTANT
  HR
  WAREHOUSE
  READ_ONLY
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum DocumentType {
  QUOTE
  INVOICE
  PROFORMA
  CREDIT_NOTE
  PURCHASE_ORDER
  DELIVERY_NOTE
  RECEIPT
}

enum DocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  REFUSED
  PAID
  PARTIALLY_PAID
  OVERDUE
}

enum PaymentMode {
  CASH
  CHECK
  TRANSFER
  CARD
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum InventoryMovementType {
  RECEIPT
  ISSUE
  TRANSFER
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RESERVATION
  RELEASE
}

enum InventoryMovementStatus {
  DRAFT
  POSTED
  CANCELLED
}

model Company {
  id                        String                     @id @default(cuid())
  name                      String
  ice                       String?
  taxId                     String?
  rc                        String?
  phone                     String?
  email                     String?
  address                   String?
  city                      String?
  logoUrl                   String?
  stampUrl                  String?
  signUrl                   String?
  users                     User[]
  clients                   Client[]
  suppliers                 Supplier[]
  products                  Product[]
  productCategories         ProductCategory[]
  documents                 Document[]
  deliveryNotes             DeliveryNote[]
  purchases                 PurchaseInvoice[]
  cashEntries               CashEntry[]
  employees                 Employee[]
  employeeContracts         EmployeeContract[]
  attendances               Attendance[]
  hrLeaves                  HrLeave[]
  salarySlips               SalarySlip[]
  salaryAdvances            SalaryAdvance[]
  hrDocuments               HrDocument[]
  expenses                  Expense[]
  categories                Category[]
  movements                 StockMovement[]
  crmCompanies              CrmCompany[]
  crmCustomers              CrmCustomer[]
  crmContacts               CrmContact[]
  crmMeetings               CrmMeeting[]
  crmTasks                  CrmTask[]
  crmNotes                  CrmNote[]
  salesQuotes               SalesQuote[]
  salesInvoices             SalesInvoice[]
  salesPayments             SalesPayment[]
  procurementSuppliers      ProcurementSupplier[]
  procurementPurchaseOrders ProcurementPurchaseOrder[]
  procurementGoodsReceipts  ProcurementGoodsReceipt[]
  inventoryWarehouses       InventoryWarehouse[]
  inventoryBalances         InventoryBalance[]
  inventoryMovements        InventoryStockMovement[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
}

model User {
  id           String     @id @default(cuid())
  companyId    String?
  company      Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(READ_ONLY)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([companyId])
  @@index([companyId, status])
}

model Client {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  contactName   String?
  ice           String?
  taxId         String?
  rc            String?
  phone         String?
  email         String?
  address       String?
  city          String?
  balance       Decimal        @default(0)
  documents     Document[]
  deliveryNotes DeliveryNote[]
  reminders     Reminder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
  @@index([companyId, ice])
}

model Supplier {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  ice         String?
  taxId       String?
  rc          String?
  phone       String?
  email       String?
  address     String?
  city        String?
  balance     Decimal           @default(0)
  purchases   PurchaseInvoice[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([companyId])
  @@index([companyId, ice])
}

model Category {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([companyId, name])
  @@index([companyId])
}

model ProductCategory {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  parentId    String?
  parent      ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[] @relation("ProductCategoryTree")
  description String?
  order       Int               @default(0)
  active      Boolean           @default(true)
  products    Product[]         @relation("ProductCatalogCategory")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, active])
  @@index([parentId])
}

model Product {
  id                            String                         @id @default(cuid())
  companyId                     String
  company                       Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId                    String?
  category                      Category?                      @relation(fields: [categoryId], references: [id])
  productCategoryId             String?
  productCategory               ProductCategory?               @relation("ProductCatalogCategory", fields: [productCategoryId], references: [id], onDelete: SetNull)
  sku                           String
  barcode                       String?
  reference                     String
  name                          String
  designation                   String
  shortDescription              String?
  description                   String?
  brand                         String?
  unit                          String                         @default("piece")
  imageUrl                      String?
  purchasePrice                 Decimal                        @default(0)
  sellingPrice                  Decimal
  salePrice                     Decimal
  vatRate                       Decimal                        @default(20)
  currency                      String                         @default("MAD")
  active                        Boolean                        @default(true)
  status                        String                         @default("active")
  notes                         String?
  trackInventory                Boolean                        @default(false)
  allowNegativeStock            Boolean                        @default(false)
  hasVariants                   Boolean                        @default(false)
  serialTracked                 Boolean                        @default(false)
  batchTracked                  Boolean                        @default(false)
  stock                         Int                            @default(0)
  minStock                      Int                            @default(0)
  lines                         DocumentLine[]
  deliveryLines                 DeliveryNoteLine[]
  purchaseLines                 PurchaseInvoiceLine[]
  procurementPurchaseOrderLines ProcurementPurchaseOrderLine[]
  procurementGoodsReceiptLines  ProcurementGoodsReceiptLine[]
  movements                     StockMovement[]
  inventoryBalances             InventoryBalance[]
  inventoryMovements            InventoryStockMovement[]
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@unique([companyId, reference])
  @@index([companyId])
  @@index([companyId, active])
  @@index([companyId, status])
  @@index([productCategoryId])
}

model Document {
  id         String         @id @default(cuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id])
  type       DocumentType
  status     DocumentStatus @default(DRAFT)
  number     String
  issueDate  DateTime       @default(now())
  dueDate    DateTime?
  subtotal   Decimal        @default(0)
  vatTotal   Decimal        @default(0)
  total      Decimal        @default(0)
  paidAmount Decimal        @default(0)
  notes      String?
  lines      DocumentLine[]
  payments   Payment[]
  sourceId   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([companyId, type, number])
  @@index([companyId, status])
  @@index([companyId, clientId])
  @@index([companyId, clientId, type])
}

model DocumentLine {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  designation String
  quantity    Decimal
  unitPrice   Decimal
  vatRate     Decimal
  total       Decimal
}

model Payment {
  id         String      @id @default(cuid())
  documentId String
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  amount     Decimal
  mode       PaymentMode
  reference  String?
  paidAt     DateTime    @default(now())
}

model DeliveryNote {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  number            String
  status            DocumentStatus     @default(DRAFT)
  issueDate         DateTime           @default(now())
  internalReference String?
  deliveryAddress   String?
  city              String?
  deliveryTerms     String?
  internalNotes     String?
  lines             DeliveryNoteLine[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([companyId, number])
  @@index([companyId, clientId])
  @@index([companyId, status])
}

model DeliveryNoteLine {
  id                String       @id @default(cuid())
  deliveryNoteId    String
  deliveryNote      DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?     @relation(fields: [productId], references: [id])
  reference         String?
  designation       String
  orderedQuantity   Decimal
  deliveredQuantity Decimal
  unit              String       @default("Pièce")
  observations      String?
}

model PurchaseInvoice {
  id         String                @id @default(cuid())
  companyId  String
  company    Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier              @relation(fields: [supplierId], references: [id])
  number     String
  status     DocumentStatus        @default(DRAFT)
  issueDate  DateTime              @default(now())
  dueDate    DateTime?
  subtotal   Decimal               @default(0)
  vatTotal   Decimal               @default(0)
  total      Decimal               @default(0)
  paidAmount Decimal               @default(0)
  notes      String?
  lines      PurchaseInvoiceLine[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([companyId, number])
  @@index([companyId, supplierId])
  @@index([companyId, status])
}

model PurchaseInvoiceLine {
  id                String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?        @relation(fields: [productId], references: [id])
  designation       String
  quantity          Decimal
  unitPrice         Decimal
  vatRate           Decimal
  total             Decimal
}

model CashEntry {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String
  category  String
  label     String
  amount    Decimal
  mode      PaymentMode
  reference String?
  entryDate DateTime    @default(now())
  createdAt DateTime    @default(now())

  @@index([companyId, entryDate])
  @@index([companyId, type])
}

model Expense {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal
  mode      PaymentMode
  spentAt   DateTime    @default(now())
  createdAt DateTime    @default(now())

  @@index([companyId])
}

model Employee {
  id           String             @id @default(cuid())
  companyId    String
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  photoUrl     String?
  firstName    String
  lastName     String
  cin          String
  phone        String?
  email        String?
  address      String?
  city         String?
  birthDate    DateTime?
  hireDate     DateTime
  position     String
  department   String
  contractType String
  baseSalary   Decimal            @default(0)
  status       String             @default("actif")
  contracts    EmployeeContract[]
  attendances  Attendance[]
  leaves       HrLeave[]
  salarySlips  SalarySlip[]
  advances     SalaryAdvance[]
  documents    HrDocument[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, cin])
}

model EmployeeContract {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type          String
  startDate     DateTime
  endDate       DateTime?
  salary        Decimal   @default(0)
  position      String
  signedFileUrl String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId, employeeId])
  @@index([companyId, type])
}

model Attendance {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workDate    DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  lateMinutes Int       @default(0)
  workedHours Decimal   @default(0)
  createdAt   DateTime  @default(now())

  @@index([companyId, employeeId])
  @@index([companyId, workDate])
}

model HrLeave {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String
  reason     String
  startDate  DateTime
  endDate    DateTime
  days       Decimal  @default(0)
  status     String   @default("en attente")
  balance    Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, employeeId])
  @@index([companyId, status])
}

model SalarySlip {
  id             String    @id @default(cuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month          String
  baseSalary     Decimal   @default(0)
  bonuses        Decimal   @default(0)
  advances       Decimal   @default(0)
  deductions     Decimal   @default(0)
  unpaidAbsences Decimal   @default(0)
  netSalary      Decimal   @default(0)
  paidAt         DateTime?
  createdAt      DateTime  @default(now())

  @@unique([companyId, employeeId, month])
  @@index([companyId, month])
}

model SalaryAdvance {
  id         String      @id @default(cuid())
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount     Decimal
  mode       PaymentMode
  paidAt     DateTime    @default(now())
  deducted   Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([companyId, employeeId])
  @@index([companyId, paidAt])
}

model HrDocument {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String
  title      String
  fileUrl    String?
  issuedAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([companyId, employeeId])
  @@index([companyId, type])
}

model StockMovement {
  id        String            @id @default(cuid())
  companyId String
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      StockMovementType
  quantity  Int
  reason    String
  reference String?
  note      String?
  createdAt DateTime          @default(now())

  @@index([companyId, productId])
  @@index([companyId, type])
  @@index([companyId, createdAt])
}

model InventoryWarehouse {
  id            String                    @id @default(cuid())
  companyId     String
  company       Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code          String
  name          String
  description   String?
  active        Boolean                   @default(true)
  isDefault     Boolean                   @default(false)
  balances      InventoryBalance[]
  movementsFrom InventoryStockMovement[]  @relation("InventoryMovementFromWarehouse")
  movementsTo   InventoryStockMovement[]  @relation("InventoryMovementToWarehouse")
  goodsReceipts ProcurementGoodsReceipt[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
  @@index([companyId, isDefault])
}

model InventoryBalance {
  id                String             @id @default(cuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId         String
  product           Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId       String
  warehouse         InventoryWarehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantityOnHand    Decimal            @default(0)
  quantityReserved  Decimal            @default(0)
  quantityAvailable Decimal            @default(0)
  reorderPoint      Decimal            @default(0)
  lastMovementDate  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([companyId, productId, warehouseId])
  @@index([companyId])
  @@index([companyId, productId])
  @@index([companyId, warehouseId])
}

model InventoryStockMovement {
  id              String                  @id @default(cuid())
  companyId       String
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId       String
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  fromWarehouseId String?
  fromWarehouse   InventoryWarehouse?     @relation("InventoryMovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouseId   String?
  toWarehouse     InventoryWarehouse?     @relation("InventoryMovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  type            InventoryMovementType
  status          InventoryMovementStatus @default(DRAFT)
  quantity        Decimal
  reference       String?
  referenceType   String?
  referenceId     String?
  reason          String?
  postedAt        DateTime?
  cancelledAt     DateTime?
  createdBy       String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([companyId])
  @@index([companyId, productId])
  @@index([companyId, type])
  @@index([companyId, referenceType, referenceId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
}

model Reminder {
  id        String   @id @default(cuid())
  companyId String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subject   String
  note      String?
  dueAt     DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([companyId, clientId])
}

model CrmCompany {
  id                 String         @id
  tenantCompanyId    String
  tenantCompany      Company        @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId        String
  legalName          String
  displayName        String
  registrationNumber String?
  taxNumber          String?
  industry           String
  website            String?
  email              String?
  phone              String?
  address            String?
  city               String?
  country            String?
  status             String
  tags               Json
  notes              String?
  ownerId            String?
  createdBy          String
  updatedBy          String?
  crmCustomers       CrmCustomer[]
  crmContacts        CrmContact[]
  crmMeetings        CrmMeeting[]
  crmTasks           CrmTask[]
  crmNotes           CrmNote[]
  salesQuotes        SalesQuote[]
  salesInvoices      SalesInvoice[]
  salesPayments      SalesPayment[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, status])
}

model CrmCustomer {
  id              String         @id
  tenantCompanyId String
  tenantCompany   Company        @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  displayName     String
  crmCompanyId    String?
  crmCompany      CrmCompany?    @relation(fields: [crmCompanyId], references: [id], onDelete: SetNull)
  companyName     String?
  email           String?
  phone           String?
  status          String
  type            String
  source          String
  tags            Json
  notes           String?
  createdBy       String
  updatedBy       String?
  salesQuotes     SalesQuote[]
  salesInvoices   SalesInvoice[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, status])
}

model CrmContact {
  id                String         @id
  tenantCompanyId   String
  tenantCompany     Company        @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId       String
  crmCompanyId      String
  crmCompany        CrmCompany     @relation(fields: [crmCompanyId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  fullName          String
  jobTitle          String?
  department        String?
  email             String?
  mobilePhone       String?
  officePhone       String?
  preferredLanguage String?
  timezone          String?
  status            String
  role              String?
  isPrimaryContact  Boolean        @default(false)
  isDecisionMaker   Boolean        @default(false)
  linkedin          String?
  notes             String?
  tags              Json
  ownerId           String?
  createdBy         String
  updatedBy         String?
  salesQuotes       SalesQuote[]
  salesInvoices     SalesInvoice[]
  salesPayments     SalesPayment[]
  crmMeetings       CrmMeeting[]
  crmTasks          CrmTask[]
  crmNotes          CrmNote[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, status])
}

model CrmMeeting {
  id              String      @id
  tenantCompanyId String
  tenantCompany   Company     @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  crmCompanyId    String
  crmCompany      CrmCompany  @relation(fields: [crmCompanyId], references: [id], onDelete: Cascade)
  crmContactId    String?
  crmContact      CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  contactIds      Json
  title           String
  description     String?
  location        String?
  meetingType     String
  status          String
  startAt         DateTime
  endAt           DateTime
  organizerId     String
  participants    Json
  notes           String?
  tags            Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, crmContactId])
  @@index([tenantCompanyId, status])
}

model CrmTask {
  id              String      @id
  tenantCompanyId String
  tenantCompany   Company     @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  crmCompanyId    String
  crmCompany      CrmCompany  @relation(fields: [crmCompanyId], references: [id], onDelete: Cascade)
  crmContactId    String?
  crmContact      CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  meetingId       String?
  title           String
  description     String?
  taskType        String
  priority        String
  status          String
  assignedTo      String
  dueDate         DateTime
  completedAt     DateTime?
  tags            Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, crmContactId])
  @@index([tenantCompanyId, status])
}

model CrmNote {
  id              String      @id
  tenantCompanyId String
  tenantCompany   Company     @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  crmCompanyId    String
  crmCompany      CrmCompany  @relation(fields: [crmCompanyId], references: [id], onDelete: Cascade)
  crmContactId    String?
  crmContact      CrmContact? @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  meetingId       String?
  taskId          String?
  title           String
  content         String
  visibility      String
  authorId        String
  tags            Json
  attachments     Json
  archivedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, crmContactId])
  @@index([tenantCompanyId, archivedAt])
}

model SalesQuote {
  id              String           @id
  tenantCompanyId String
  tenantCompany   Company          @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  number          String
  crmCustomerId   String?
  crmCustomer     CrmCustomer?     @relation(fields: [crmCustomerId], references: [id], onDelete: SetNull)
  customerName    String
  crmCompanyId    String
  crmCompany      CrmCompany       @relation(fields: [crmCompanyId], references: [id], onDelete: Restrict)
  companyName     String?
  crmContactId    String?
  crmContact      CrmContact?      @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  contactName     String?
  opportunityId   String?
  opportunityName String?
  status          String
  issueDate       DateTime
  expirationDate  DateTime
  validityDays    Int?
  currency        String
  discountRate    Float            @default(0)
  notes           String?
  ownerId         String
  lines           SalesQuoteLine[]
  salesInvoices   SalesInvoice[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([tenantCompanyId, number])
  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, crmCustomerId])
  @@index([tenantCompanyId, status])
}

model SalesQuoteLine {
  id          String     @id
  quoteId     String
  quote       SalesQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float
  position    Int

  @@index([quoteId])
}

model SalesInvoice {
  id              String             @id
  tenantCompanyId String
  tenantCompany   Company            @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  number          String
  crmCustomerId   String?
  crmCustomer     CrmCustomer?       @relation(fields: [crmCustomerId], references: [id], onDelete: SetNull)
  customerName    String
  crmCompanyId    String
  crmCompany      CrmCompany         @relation(fields: [crmCompanyId], references: [id], onDelete: Restrict)
  companyName     String?
  crmContactId    String?
  crmContact      CrmContact?        @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  contactName     String?
  opportunityId   String?
  opportunityName String?
  quoteId         String?
  quote           SalesQuote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  status          String
  issueDate       DateTime
  dueDate         DateTime
  currency        String
  discountRate    Float              @default(0)
  notes           String?
  ownerId         String
  paidAmount      Float              @default(0)
  archivedAt      DateTime?
  lines           SalesInvoiceLine[]
  payments        SalesPayment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([tenantCompanyId, number])
  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, crmCustomerId])
  @@index([tenantCompanyId, quoteId])
  @@index([tenantCompanyId, status])
}

model SalesInvoiceLine {
  id          String       @id
  invoiceId   String
  invoice     SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float
  position    Int

  @@index([invoiceId])
}

model SalesPayment {
  id              String       @id
  tenantCompanyId String
  tenantCompany   Company      @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  number          String
  invoiceId       String
  invoice         SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceNumber   String
  customerName    String
  crmCompanyId    String
  crmCompany      CrmCompany   @relation(fields: [crmCompanyId], references: [id], onDelete: Restrict)
  crmContactId    String?
  crmContact      CrmContact?  @relation(fields: [crmContactId], references: [id], onDelete: SetNull)
  opportunityId   String?
  status          String
  method          String
  amount          Float
  currency        String
  receivedAt      DateTime
  reference       String?
  notes           String?
  ownerId         String
  archivedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([tenantCompanyId, number])
  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, invoiceId])
  @@index([tenantCompanyId, crmCompanyId])
  @@index([tenantCompanyId, status])
}

model ProcurementSupplier {
  id              String                     @id
  tenantCompanyId String
  tenantCompany   Company                    @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  companyName     String
  tradeName       String?
  ice             String?
  taxId           String?
  rc              String?
  vat             String?
  phone           String?
  email           String?
  address         String?
  country         String
  currency        String
  paymentTerms    String?
  notes           String?
  status          String
  active          Boolean                    @default(true)
  archivedAt      DateTime?
  purchaseOrders  ProcurementPurchaseOrder[]
  goodsReceipts   ProcurementGoodsReceipt[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, active])
  @@index([tenantCompanyId, status])
  @@index([tenantCompanyId, ice])
}

model ProcurementPurchaseOrder {
  id              String                         @id
  tenantCompanyId String
  tenantCompany   Company                        @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId     String
  number          String
  supplierId      String
  supplier        ProcurementSupplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierName    String
  status          String
  issueDate       DateTime
  expectedDate    DateTime?
  currency        String
  reference       String?
  notes           String?
  discountRate    Float                          @default(0)
  archivedAt      DateTime?
  ownerId         String?
  lines           ProcurementPurchaseOrderLine[]
  goodsReceipts   ProcurementGoodsReceipt[]
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@unique([tenantCompanyId, number])
  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, supplierId])
  @@index([tenantCompanyId, status])
}

model ProcurementPurchaseOrderLine {
  id                String                        @id
  purchaseOrderId   String
  purchaseOrder     ProcurementPurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  goodsReceiptLines ProcurementGoodsReceiptLine[]
  productId         String?
  product           Product?                      @relation(fields: [productId], references: [id], onDelete: SetNull)
  productSku        String?
  productName       String?
  description       String
  quantity          Float
  unit              String
  unitPrice         Float
  discountRate      Float                         @default(0)
  taxRate           Float                         @default(0)
  position          Int

  @@index([purchaseOrderId])
  @@index([productId])
}

model ProcurementGoodsReceipt {
  id                  String                        @id
  tenantCompanyId     String
  tenantCompany       Company                       @relation(fields: [tenantCompanyId], references: [id], onDelete: Cascade)
  workspaceId         String
  number              String
  supplierId          String
  supplier            ProcurementSupplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierName        String
  purchaseOrderId     String
  purchaseOrder       ProcurementPurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  purchaseOrderNumber String
  warehouseId         String
  warehouse           InventoryWarehouse            @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  warehouseName       String?
  receiptDate         DateTime
  status              String
  reference           String?
  notes               String?
  postedAt            DateTime?
  archivedAt          DateTime?
  ownerId             String?
  lines               ProcurementGoodsReceiptLine[]
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@unique([tenantCompanyId, number])
  @@index([tenantCompanyId, workspaceId])
  @@index([tenantCompanyId, supplierId])
  @@index([tenantCompanyId, purchaseOrderId])
  @@index([tenantCompanyId, warehouseId])
  @@index([tenantCompanyId, status])
}

model ProcurementGoodsReceiptLine {
  id                         String                       @id
  goodsReceiptId             String
  goodsReceipt               ProcurementGoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderLineId        String
  purchaseOrderLine          ProcurementPurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  productId                  String
  product                    Product                      @relation(fields: [productId], references: [id], onDelete: Restrict)
  productSku                 String?
  productName                String?
  description                String
  orderedQuantity            Float
  previouslyReceivedQuantity Float
  receivedQuantity           Float
  unit                       String
  position                   Int

  @@index([goodsReceiptId])
  @@index([purchaseOrderLineId])
  @@index([productId])
}
